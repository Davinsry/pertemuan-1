{
    "info": {
        "_postman_id": "belajar-laravel-api-pertemuan-9",
        "name": "Belajar Laravel - API Pertemuan 9",
        "description": "Koleksi testing API CRUD untuk Product & Category dengan Laravel Sanctum Authentication. Import ke Postman, set base_url sesuai server, lalu run login terlebih dahulu.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. AUTH - Login (Dapatkan Token)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/api/login",
                    "host": ["{{base_url}}"],
                    "path": ["api", "login"]
                },
                "description": "Login untuk mendapatkan access_token. Copy value access_token ke Postman variable `access_token` (klik icon mata di sebelah kanan atas Postman → Environment / Global → tambah variable `access_token`)."
            },
            "response": []
        },
