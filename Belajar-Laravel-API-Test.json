        {
            "name": "PRODUCT - POST Create (Auth)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{access_token}}",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"name\": \"Laptop Gaming\",\n    \"qty\": 10,\n    \"price\": 15000000,\n    \"user_id\": 1,\n    \"category_id\": 1\n}"
                },
                "url": {
                    "raw": "{{base_url}}/api/product",
                    "host": ["{{base_url}}"],
                    "path": ["api", "product"]
                },
                "description": "Pastikan category_id tersedia di tabel categories. Ubah user_id & category_id sesuai data di database kamu."
            },
            "response": []
        },
